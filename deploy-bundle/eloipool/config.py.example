#   BLAKESTREAM_AUX_CHAINS[0]['rpc_uri'], BLAKESTREAM_AUX_CHAINS[0]['pool_address'],
#   BLAKESTREAM_AUX_CHAINS[1]['rpc_uri'], BLAKESTREAM_AUX_CHAINS[1]['pool_address'],
#   BLAKESTREAM_AUX_CHAINS[2]['rpc_uri'], BLAKESTREAM_AUX_CHAINS[2]['pool_address'],
