# Example merged-mine proxy launch using the six-chain defaults above:
# python3 merged-mine-proxy.py3 -w %d -p http://%s:%s@127.0.0.1:%d/ -s 16 \
#   -x %s -a %s \
#   -x %s -a %s \
#   -x %s -a %s \
#   -x %s -a %s \
#   -x %s -a %s
# % (
#   PROXY_PORT,
